{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Win12",
  "version": "0.1.0",
  "identifier": "com.oliver.win12",
  "build": {
    "frontendDist": "../..",
    "devUrl": null
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Win12",
        "url": "boot.html",
        "width": 1280,
        "height": 720,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}

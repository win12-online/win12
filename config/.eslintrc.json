{
  "root": true,
  "env": {
    "browser": true,
    "es2021": true,
    "node": true
  },
  "extends": [
    "eslint:recommended"
  ],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "ignorePatterns": [
    "*.html",
    "node_modules/",
    "coverage/",
    "playwright-report/",
    "test-results/",
    "public/**",
    "pwa/",
    "readme/",
    "lang/",
    "docs/"
  ],
  "globals": {
    "$": "readonly",
    "jQuery": "readonly",
    "lang": "readonly",
    "openapp": "readonly",
    "hidewin": "readonly",
    "showwin": "readonly",
    "shownotice": "readonly",
    "closenotice": "readonly",
    "showcm": "readonly",
    "toggletheme": "readonly",
    "setData": "readonly",
    "stop": "readonly",
    "api": "readonly",
    "run_cmd": "readonly",
    "runcmd": "readonly",
    "nts": "readonly",
    "taskmgrTasks": "readonly",
    "desktopItem": "readonly",
    "addMenu": "readonly",
    "saveDesktop": "readonly",
    "wo": "readonly",
    "fil": "readonly",
    "fil_type": "readonly",
    "filty": "readonly",
    "page": "readonly",
    "i18nData": "readonly",
    "geticon": "readonly",
    "news": "readonly",
    "orderwin": "readonly",
    "maxwin": "readonly"
  },
  "rules": {
    "no-unused-vars": [
      "warn",
      {
        "argsIgnorePattern": "^_"
      }
    ],
    "no-console": [
      "warn",
      {
        "allow": ["warn", "error", "log"]
      }
    ]
  },
  "overrides": [
    {
      "files": ["tests/**/*.{js,test.js,spec.js}"],
      "env": {
        "node": true
      },
      "globals": {
        "describe": "readonly",
        "it": "readonly",
        "test": "readonly",
        "expect": "readonly",
        "beforeEach": "readonly",
        "afterEach": "readonly",
        "beforeAll": "readonly",
        "afterAll": "readonly",
        "vi": "readonly"
      },
      "rules": {
        "no-unused-vars": [
          "warn",
          {
            "argsIgnorePattern": "^_"
          }
        ]
      }
    }
  ]
}

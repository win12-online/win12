{
  "name": "win12-online",
  "version": "1.0.0",
  "description": "Windows 12 Web Simulation - Open Source Project",
  "type": "module",
  "scripts": {
    "test": "vitest --config config/vitest.config.js",
    "test:ui": "vitest --ui --config config/vitest.config.js",
    "test:coverage": "vitest --coverage --config config/vitest.config.js",
    "test:e2e": "playwright test --config config/playwright.config.js",
    "test:e2e:ui": "playwright test --ui --config config/playwright.config.js",
    "test:all": "npm run test && npm run test:e2e",
    "lint": "eslint . --ext .js,.html --config config/.eslintrc.json",
    "lint:fix": "eslint . --ext .js,.html --fix --config config/.eslintrc.json"
  },
  "dependencies": {
    "jquery": "^3.7.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@vitest/ui": "^1.0.0",
    "eslint": "^8.55.0",
    "vitest": "^1.0.0",
    "jsdom": "^23.0.0",
    "@vitest/coverage-v8": "^1.0.0"
  }
}
